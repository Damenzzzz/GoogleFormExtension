{
  "manifest_version": 3,
  "name": "Local AI Google Form Filler",
  "description": "Preview and safely fill Google Forms using a local AI configuration.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://docs.google.com/forms/*",
    "https://llm.alem.ai/*"
  ],
  "action": {
    "default_title": "AI Form Filler",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/forms/*"
      ],
      "js": [
        "src/formParser.js",
        "src/formFiller.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
